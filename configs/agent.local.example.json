{
  "server": {
    "host": "127.0.0.1",
    "port": 8765
  },
  "echomemory": {
    "base_url": "http://127.0.0.1:8000",
    "timeout_seconds": 15
  },
  "model": {
    "provider": "openai_compatible",
    "base_url": "http://127.0.0.1:11434/v1",
    "api_key": "local-key",
    "model": "openclaw-default",
    "temperature": 0.3,
    "max_tokens": 1024,
    "timeout_seconds": 60
  },
  "chat": {
    "system_prompt": "你是一个接入 EchoMemory 的任务型 Agent。回答要清晰、可靠，并说明关键依据。",
    "history_turns": 8,
    "retrieval_enabled": true,
    "retrieval_limit": 6,
    "auto_commit": "manual",
    "context_budget_tokens": 12000
  }
}
